{
    "realm": "sentinel",
    "enabled": true,
    "roles": {
        "realm": [
            {
                "name": "owner",
                "description": "Sentinel Company - platform owner"
            },
            {
                "name": "support-team",
                "description": "Sentinel Company - platform-wide support role"
            },
            {
                "name": "cso",
                "description": "Customer Organization - executive role"
            },
            {
                "name": "security-administrator",
                "description": "Customer Organization - operational admin"
            },
            {
                "name": "security-analyst",
                "description": "Customer Organization - investigation role"
            }
        ]
    },
    "clients": [
        {
            "clientId": "sentinel-dashboard",
            "publicClient": true,
            "redirectUris": [
                "http://localhost:3000/*"
            ],
            "webOrigins": [
                "http://localhost:3000"
            ],
            "standardFlowEnabled": true,
            "directAccessGrantsEnabled": false
        },
        {
            "clientId": "sentinel-api",
            "publicClient": false,
            "secret": "change-this-secret",
            "serviceAccountsEnabled": true,
            "standardFlowEnabled": false,
            "directAccessGrantsEnabled": false,
            "protocolMappers": [
                {
                    "name": "organizationId",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-attribute-mapper",
                    "config": {
                        "user.attribute": "organizationId",
                        "claim.name": "organizationId",
                        "jsonType.label": "String",
                        "access.token.claim": "true"
                    }
                }
            ]
        }
    ],
    "users": [
        {
            "username": "bootstrap-owner",
            "enabled": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "change-this-password",
                    "temporary": true
                }
            ],
            "realmRoles": [
                "owner"
            ]
        }
    ]
}